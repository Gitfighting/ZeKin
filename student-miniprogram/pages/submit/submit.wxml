<view class="page">
  <view class="title">提交打卡</view>
  <view class="card">
    <view class="chip {{type === 'dorm' ? 'active' : ''}}" data-type="dorm" bindtap="chooseType">查寝</view>
    <view class="chip {{type === 'class' ? 'active' : ''}}" data-type="class" bindtap="chooseType">上课</view>
    <view class="chip {{type === 'internship' ? 'active' : ''}}" data-type="internship" bindtap="chooseType">实习</view>
  </view>
  <view class="card">
    <textarea value="{{content}}" placeholder="请输入今日情况，最多 280 字" maxlength="280" bindinput="onContentInput" />
    <view class="muted">{{content.length}}/280</view>
  </view>
  <view class="card">
    <button>上传照片</button>
    <button bindtap="getLocation">获取定位</button>
    <view class="muted">当前位置：{{lat ? lat + ',' + lng : '等待获取'}}</view>
  </view>
  <button class="primary-button" loading="{{loading}}" bindtap="submit">提交打卡</button>
</view>
