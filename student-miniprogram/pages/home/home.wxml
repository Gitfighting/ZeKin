<view class="page">
  <view class="title">今日打卡</view>
  <view class="card">
    <view class="muted">2026-06-23</view>
    <view class="title">{{statusText}}</view>
    <button class="primary-button" bindtap="goSubmit">立即打卡</button>
  </view>
  <view class="card">
    <view class="chip active">查寝</view>
    <view class="chip">上课</view>
    <view class="chip">实习</view>
  </view>
  <view class="card">
    <view class="muted">最近记录</view>
    <block wx:if="{{recent.length}}">
      <view wx:for="{{recent}}" wx:key="id">{{item.type}} · {{item.status}} · {{item.content}}</view>
    </block>
    <view wx:else>暂无打卡记录</view>
  </view>
</view>
