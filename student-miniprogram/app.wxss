page {
  background: #f9fafb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.muted {
  color: #6b7280;
  font-size: 24rpx;
}

.primary-button {
  background: #3b82f6;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.chip {
  background: #f3f4f6;
  border-radius: 999rpx;
  color: #6b7280;
  display: inline-block;
  font-size: 24rpx;
  margin-right: 12rpx;
  padding: 8rpx 24rpx;
}

.chip.active {
  background: #3b82f6;
  color: #ffffff;
}
