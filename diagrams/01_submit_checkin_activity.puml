@startuml
title UC-02 提交打卡 活动图
skinparam backgroundColor #F8FAFC
skinparam shadowing false
skinparam activity {
  BackgroundColor #FFFFFF
  BorderColor #2563EB
  FontColor #0F172A
  DiamondBackgroundColor #DBEAFE
  DiamondBorderColor #2563EB
}

start
partition "学生" {
  :进入今日打卡页;
  :选择打卡类型\n查寝/上课/实习;
  :填写打卡内容;
}
partition "系统" {
  :请求定位服务;
}
partition "定位服务" {
  if (定位成功?) then (是)
    :返回经纬度;
  else (否)
    :返回定位失败;
  endif
}
partition "系统" {
  if (定位成功?) then (是)
    :记录正常定位;
  else (否)
    :标记定位异常\n但不阻断提交;
  endif
}
partition "学生" {
  :点击提交;
}
partition "系统" {
  if (内容合规?) then (是)
    if (同日同类型已打卡?) then (是)
      :拒绝提交并提示重复打卡;
      stop
    else (否)
      :保存打卡记录;
      :状态设为待教师审核;
      :刷新今日状态;
    endif
  else (否)
    :提示补充或修改内容;
    stop
  endif
}
partition "学生" {
  :看到提交成功提示;
}
stop
@enduml
