@startuml
title UC-05 查看统计概览 活动图
skinparam backgroundColor #F8FAFC
skinparam shadowing false
skinparam activity {
  BackgroundColor #FFFFFF
  BorderColor #7C3AED
  FontColor #0F172A
  DiamondBackgroundColor #F3E8FF
  DiamondBorderColor #7C3AED
}

start
partition "教师/管理员" {
  :进入统计概览页;
}
partition "系统" {
  :识别用户角色;
  if (用户是否管理员?) then (是)
    :设置数据范围为全校;
  else (教师)
    :设置数据范围为所管班级;
  endif
  :聚合今日应打卡人数;
  :聚合已打卡人数;
  :计算打卡率;
  :统计待审核数与异常数;
}
partition "教师/管理员" {
  :查看指标卡片;
  if (是否存在待审核或异常?) then (是)
    :点击进入审核列表;
  else (否)
    :结束查看;
  endif
}
stop
@enduml
