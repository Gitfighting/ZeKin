meta {
  name: ZeKin E2E
  type: collection
}

script:pre-request {
  const now = new Date();
  const pad = (n) => String(n).padStart(2, '0');
  const today = `${now.getFullYear()}-${pad(now.getMonth() + 1)}-${pad(now.getDate())}`;
  bru.setEnvVar('today', today);
  bru.setEnvVar('starts_at', `${today}T08:00:00`);
  bru.setEnvVar('ends_at', `${today}T22:00:00`);
  bru.setEnvVar('report_date', today);
}
