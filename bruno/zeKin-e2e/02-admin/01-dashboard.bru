meta {
  name: 01 管理员看板
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/admin/dashboard
  body: none
  auth: bearer
}

auth:bearer {
  token: {{admin_token}}
}

tests {
  test("状态码 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("包含任务统计", function() {
    const body = res.getBody();
    expect(body.data).to.have.property("task_count");
  });
}
