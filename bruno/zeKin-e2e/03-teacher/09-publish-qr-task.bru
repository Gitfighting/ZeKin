meta {
  name: 09 发布二维码任务
  type: http
  seq: 9
}

post {
  url: {{base_url}}/api/teacher/tasks/{{qr_task_id}}/publish
  body: none
  auth: bearer
}

auth:bearer {
  token: {{teacher_token}}
}

tests {
  test("状态码 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("发布成功", function() {
    const body = res.getBody();
    expect(body.data.published).to.equal(true);
  });
}
