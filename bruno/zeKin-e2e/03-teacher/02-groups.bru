meta {
  name: 02 教师班级群
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/teacher/groups
  body: none
  auth: bearer
}

auth:bearer {
  token: {{teacher_token}}
}

tests {
  test("状态码 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("至少一个班级", function() {
    const body = res.getBody();
    expect(body.data.total).to.be.at.least(1);
  });
}
