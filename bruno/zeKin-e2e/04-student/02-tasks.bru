meta {
  name: 02 学生任务列表
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/student/tasks
  body: none
  auth: bearer
}

auth:bearer {
  token: {{student_token}}
}

tests {
  test("状态码 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("包含已发布任务", function() {
    const body = res.getBody();
    expect(body.data.total).to.be.at.least(1);
  });
}
