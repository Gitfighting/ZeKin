meta {
  name: 01 学生看板
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/student/dashboard
  body: none
  auth: bearer
}

auth:bearer {
  token: {{student_token}}
}

tests {
  test("状态码 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("包含任务与记录统计", function() {
    const body = res.getBody();
    expect(body.data).to.have.property("task_count");
    expect(body.data).to.have.property("record_count");
  });
}
