meta {
  name: 03 学生任务详情
  type: http
  seq: 3
}

get {
  url: {{base_url}}/api/student/tasks/{{task_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{student_token}}
}

tests {
  test("状态码 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("任务标题匹配", function() {
    const body = res.getBody();
    expect(body.data.title).to.include("Bruno-E2E");
  });
}
