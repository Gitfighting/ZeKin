meta {
  name: 04 当前用户
  type: http
  seq: 4
}

get {
  url: {{base_url}}/api/auth/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{student_token}}
}

tests {
  test("状态码 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("返回学生信息", function() {
    const body = res.getBody();
    expect(body.data.user_type).to.equal("student");
  });
}
