# 高德地图 Web 服务 Key（地点搜索 / 逆地理编码）
# 申请地址：https://console.amap.com/dev/key/app
VITE_AMAP_WEB_KEY=

# 后端 API 基址（开发时须与 uvicorn 端口一致，修改后需重新 npm run dev:mp-weixin）
VITE_API_BASE_URL=http://192.168.165.19:8000/api

# 微信小程序 AppID（测试号/正式小程序均可；也可改用 project.private.config.json）
# 勿使用 touristappid，否则会反复出现 webapi_getwxaasyncsecinfo:fail
VITE_WX_APPID=
