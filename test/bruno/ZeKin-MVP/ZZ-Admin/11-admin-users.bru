meta {
  name: 11 Admin Users
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/api/admin/users
  auth: bearer
}

auth:bearer {
  token: {{admin_token}}
}

headers {
  X-Client: admin-web
}

tests {
  test("admin can list shared users", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().data.items.length).to.be.greaterThan(0);
  });
}
