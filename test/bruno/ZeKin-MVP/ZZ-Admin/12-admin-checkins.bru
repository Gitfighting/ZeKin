meta {
  name: 12 Admin Checkins
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/api/admin/checkins
  auth: bearer
}

auth:bearer {
  token: {{admin_token}}
}

headers {
  X-Client: admin-web
}

tests {
  test("admin can list shared checkins", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().data.items.length).to.be.greaterThan(0);
  });
}
