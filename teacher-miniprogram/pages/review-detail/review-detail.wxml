<view class="page">
  <view class="title">审核详情</view>
  <view class="card">
    <view>{{item.student_name}} · {{item.class_name}}</view>
    <view class="muted">{{item.type}} · {{item.created_at}}</view>
  </view>
  <view class="card">{{item.content}}</view>
  <view class="card">
    <textarea value="{{comment}}" placeholder="填写评语，拒绝时必填" bindinput="onCommentInput" />
  </view>
  <button data-action="rejected" loading="{{loading}}" bindtap="review">拒绝</button>
  <button class="primary-button" data-action="approved" loading="{{loading}}" bindtap="review">通过</button>
</view>
